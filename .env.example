# AI Provider — pick ONE as default, others are fallbacks
# ── FREE OPTIONS (recommended) ────────────────────────────────────────────────
GEMINI_API_KEY=AIza-your-google-ai-studio-key-here    # Free at aistudio.google.com
GROQ_API_KEY=gsk_your-groq-key-here                   # Free at console.groq.com
DEEPSEEK_API_KEY=sk-your-deepseek-key-here            # Near-free at platform.deepseek.com

# ── LOCAL (Ollama — fully offline, no key needed) ─────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434               # Run: ollama pull qwen2.5-coder:7b

# ── PAID OPTIONS (fallback / higher quality) ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here

# Provider to use: gemini | groq | deepseek | ollama | anthropic | openai
DEFAULT_AI_PROVIDER=gemini

# Model per provider:
#   gemini    → gemini-2.5-flash  (free, fast, great for code)
#   groq      → llama-3.3-70b-versatile  OR  deepseek-r1-distill-llama-70b
#   deepseek  → deepseek-coder    (best code model, near-free)
#   ollama    → qwen2.5-coder:7b  (local, needs 8GB RAM)
#   anthropic → claude-sonnet-4-6
#   openai    → gpt-4o
AI_MODEL=gemini-2.5-flash
AI_TEMPERATURE=0.0

# Docker Config
DOCKER_IMAGE_NAME=laravel-sandbox:latest
DOCKER_NETWORK=repair-net
CONTAINER_MEMORY_LIMIT=512m
CONTAINER_CPU_LIMIT=0.5
CONTAINER_PID_LIMIT=64
CONTAINER_TIMEOUT_SECONDS=90
MAX_ITERATIONS=7

# App Config
DATABASE_URL=sqlite+aiosqlite:///./data/repair.db
MAX_CODE_SIZE_KB=100
SECRET_KEY=change-this-in-production-use-a-long-random-string
DEBUG=false

# Mutation Gate (Gemini recommendation)
MUTATION_SCORE_THRESHOLD=80

# Laravel Sandbox (injected into each Docker container)
SANDBOX_DB_HOST=mysql
SANDBOX_DB_PORT=3306
SANDBOX_DB_DATABASE=laravel
SANDBOX_DB_USERNAME=laravel
SANDBOX_DB_PASSWORD=secret
SANDBOX_REDIS_HOST=redis
