# ─────────────────────────────────────────────────────────────────────────────
# template.env — Production Environment Variables for LaraVibe
# Copy these values into your Koyeb Service Settings / Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment Configuration ──
REPAIR_ENV=production
DEBUG=false

# ── Security ──
# CRITICAL: Change these to unique random strings in production!
MASTER_REPAIR_TOKEN=your-very-long-secure-token-here
JWT_SECRET_KEY=your-another-secure-token-here

# ── AI Providers (Set at least one) ──
# RECOMMENDATION: Use Nvidia or Dashscope for the most reliable coding performance.
NVIDIA_API_KEY=
DASHSCOPE_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=

# ── AI Orchestration ──
DEFAULT_AI_PROVIDER=nvidia
USE_ROLE_PIPELINE=true

# ── Database ──
# On Koyeb, SQLite data will be wiped on every redeploy.
# For persistent data, you may eventually want to switch to a real Postgres URL.
DATABASE_URL=sqlite+aiosqlite:///./data/repair.db

# ── CORS ──
# Set this to the URL where your Frontend is hosted (e.g., Vercel or local IP)
ALLOWED_ORIGINS=https://laravibe-ui.vercel.app,http://localhost:5173
