# ─────────────────────────────────────────────────────────────────────────────
# template.env — Production Environment Variables for LaraVibe
# Copy these values into your Koyeb Service Settings / Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Infrastructure ──
REPAIR_ENV=production
DEBUG=false
# Koyeb injects PORT automatically, but you can set a default here
PORT=8000

# ── Security ──
# CRITICAL: Change these to unique random strings in your Koyeb Dashboard!
MASTER_REPAIR_TOKEN=laravibe-secure-token-2026
JWT_SECRET_KEY=generate-a-new-secret-key-for-prod
JWT_ALGORITHM=HS256

# ── AI Providers (At least one required) ──
# Get these from their respective dashboards
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
NVIDIA_API_KEY=
DASHSCOPE_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=

# ── Orchestration ──
# fallback | qwen | cerebras | gemini | groq | deepseek | ollama | anthropic | openai
DEFAULT_AI_PROVIDER=anthropic
USE_ROLE_PIPELINE=true
MAX_ITERATIONS=4

# ── Database ──
# Default uses local SQLite. NOTE: SQLite on Koyeb wipes on redeploy.
DATABASE_URL=sqlite+aiosqlite:///./data/repair.db

# ── CORS Configuration ──
# Separate multiple URLs with commas. 
# MUST include your Koyeb domain and your local dev URL if testing locally.
ALLOWED_ORIGINS=https://laravibe.koyeb.app,http://localhost:5173
